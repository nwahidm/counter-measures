{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://gitlab.com/bintangpratama/kejaksaan-sso"
        }
    ],
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^2.1",
        "diglactic/laravel-breadcrumbs": "^9.0.0",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.8",
        "kejaksaan/sso": "dev-main",
        "laravel/fortify": "^1.21.1",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.5",
        "maatwebsite/excel": "^3.1.55",
        "mews/captcha": "^3.3",
        "mpdf/mpdf": "^8.2",
        "munafio/chatify": "^1.6",
        "pbmedia/laravel-ffmpeg": "^8.5",
        "php-ffmpeg/php-ffmpeg": "^1.2",
        "php-open-source-saver/jwt-auth": "^2.2",
        "phpoffice/phpword": "^1.3",
        "phpseclib/phpseclib": "^3.0",
        "predis/predis": "^2.2",
        "protonemedia/laravel-xss-protection": "^1.6",
        "psr/simple-cache": "^3.0",
        "ryuamy/whatsapp-qiscus-php": "^1.0",
        "spatie/laravel-html": "^3.7.0",
        "spatie/laravel-permission": "^6.4.0",
        "spatie/laravel-sluggable": "^3.6",
        "symfony/process": "^7.1",
        "yajra/laravel-datatables": "^11.0.0 "
    },
    "require-dev": {
        "fakerphp/faker": "^1.23.1",
        "laravel/sail": "^1.29.1",
        "mockery/mockery": "^1.6.11",
        "mrdebug/crudgen": "^1.10",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.5.16",
        "spatie/laravel-ignition": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
